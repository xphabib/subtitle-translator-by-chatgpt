{
  "manifest_version": 3,
  "name": "ChatGPT Batch Submitter",
  "version": "1.0",
  "description": "Submit large text to ChatGPT in batches automatically",
  "permissions": ["activeTab", "scripting", "tabs", "sidePanel", "storage", "unlimitedStorage"],
  "action": {
    "default_title": "Open ChatGPT Batch Submitter"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ]
}
